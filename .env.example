# PHANTOM — Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# Trading mode (false = paper, true = real money)
LIVE_MODE=false

# Bybit API keys (only needed for live trading)
EXCHANGE_API_KEY=
EXCHANGE_SECRET=

# Telegram notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
